// -*- mode: Bluespec; -*-
// KERNEL-COVERAGE: qnt-owner CREATION.SPELL_ACCESS.PACT_MAGIC_PROGRESSION CREATION.ELDRITCH_INVOCATION.CHOICE_LIFECYCLE

module characterCreationWarlockEldritchInvocationsSelectedIdentityMbt {
  type CharacterCreationWarlockEldritchInvocationsSelectedIdentityOutcome =
    | CharacterCreationWarlockEldritchInvocationsSelectedIdentityInit
    | CharacterCreationWarlockEldritchInvocationsSelectedIdentityLevelOneSelected
    | CharacterCreationWarlockEldritchInvocationsSelectedIdentityLevelTwoGained
    | CharacterCreationWarlockEldritchInvocationsSelectedIdentityNonRepeatableReplaced
    | CharacterCreationWarlockEldritchInvocationsSelectedIdentityRepeatableReplaced
    | CharacterCreationWarlockEldritchInvocationsSelectedIdentityLockedReplacementRejected
    | CharacterCreationWarlockEldritchInvocationsSelectedIdentityDuplicateSelectionRejected

  type CharacterCreationWarlockEldritchInvocationsSelectedIdentityState = {
    outcome: CharacterCreationWarlockEldritchInvocationsSelectedIdentityOutcome,
    selectedFromUnitId: str,
    selectedInvocationCount: int,
    selectedClassChoiceFeatureRefCount: int,
    warlockInvocationsUnitRefPresent: bool,
    armorOfShadowsInvocationPresent: bool,
    pactBladeInvocationPresent: bool,
    devilsSightInvocationPresent: bool,
    eldritchMindInvocationPresent: bool,
    thirstingBladeInvocationPresent: bool,
    repellingBlastEldritchBlastPresent: bool,
    repellingBlastPoisonSprayPresent: bool,
    armorOfShadowsUnitRefPresent: bool,
    pactMagicCantripCount: int,
    pactMagicPreparedSpellCount: int,
    pactMagicSlotCount: int,
    pactMagicSlotLevel: int,
    totalLevel: int,
    lockedReplacementRejected: bool,
    duplicateNonRepeatableRejected: bool,
    duplicateRepeatableChoiceRejected: bool,
  }

  var qState: CharacterCreationWarlockEldritchInvocationsSelectedIdentityState

  action recordProjection(
    outcome: CharacterCreationWarlockEldritchInvocationsSelectedIdentityOutcome,
    selectedFromUnitId: str,
    selectedInvocationCount: int,
    selectedClassChoiceFeatureRefCount: int,
    warlockInvocationsUnitRefPresent: bool,
    armorOfShadowsInvocationPresent: bool,
    pactBladeInvocationPresent: bool,
    devilsSightInvocationPresent: bool,
    eldritchMindInvocationPresent: bool,
    thirstingBladeInvocationPresent: bool,
    repellingBlastEldritchBlastPresent: bool,
    repellingBlastPoisonSprayPresent: bool,
    armorOfShadowsUnitRefPresent: bool,
    pactMagicCantripCount: int,
    pactMagicPreparedSpellCount: int,
    pactMagicSlotCount: int,
    pactMagicSlotLevel: int,
    totalLevel: int,
    lockedReplacementRejected: bool,
    duplicateNonRepeatableRejected: bool,
    duplicateRepeatableChoiceRejected: bool,
  ): bool = all {
    qState' = {
      outcome: outcome,
      selectedFromUnitId: selectedFromUnitId,
      selectedInvocationCount: selectedInvocationCount,
      selectedClassChoiceFeatureRefCount: selectedClassChoiceFeatureRefCount,
      warlockInvocationsUnitRefPresent: warlockInvocationsUnitRefPresent,
      armorOfShadowsInvocationPresent: armorOfShadowsInvocationPresent,
      pactBladeInvocationPresent: pactBladeInvocationPresent,
      devilsSightInvocationPresent: devilsSightInvocationPresent,
      eldritchMindInvocationPresent: eldritchMindInvocationPresent,
      thirstingBladeInvocationPresent: thirstingBladeInvocationPresent,
      repellingBlastEldritchBlastPresent: repellingBlastEldritchBlastPresent,
      repellingBlastPoisonSprayPresent: repellingBlastPoisonSprayPresent,
      armorOfShadowsUnitRefPresent: armorOfShadowsUnitRefPresent,
      pactMagicCantripCount: pactMagicCantripCount,
      pactMagicPreparedSpellCount: pactMagicPreparedSpellCount,
      pactMagicSlotCount: pactMagicSlotCount,
      pactMagicSlotLevel: pactMagicSlotLevel,
      totalLevel: totalLevel,
      lockedReplacementRejected: lockedReplacementRejected,
      duplicateNonRepeatableRejected: duplicateNonRepeatableRejected,
      duplicateRepeatableChoiceRejected: duplicateRepeatableChoiceRejected,
    },
  }

  action init =
    recordProjection(
      CharacterCreationWarlockEldritchInvocationsSelectedIdentityInit,
      "none",
      0,
      0,
      false,
      false,
      false,
      false,
      false,
      false,
      false,
      false,
      false,
      0,
      0,
      0,
      0,
      1,
      false,
      false,
      false,
    )

  action doSelectLevelOneArmorOfShadows = all {
    qState.outcome == CharacterCreationWarlockEldritchInvocationsSelectedIdentityInit,
    recordProjection(
      CharacterCreationWarlockEldritchInvocationsSelectedIdentityLevelOneSelected,
      "warlock_eldritch_invocations",
      1,
      0,
      true,
      true,
      false,
      false,
      false,
      false,
      false,
      false,
      false,
      2,
      2,
      1,
      1,
      1,
      false,
      false,
      false,
    ),
  }

  action doGainLevelTwoInvocations = all {
    qState.outcome == CharacterCreationWarlockEldritchInvocationsSelectedIdentityInit,
    recordProjection(
      CharacterCreationWarlockEldritchInvocationsSelectedIdentityLevelTwoGained,
      "warlock_eldritch_invocations",
      3,
      0,
      true,
      true,
      true,
      true,
      false,
      false,
      false,
      false,
      false,
      2,
      3,
      2,
      1,
      2,
      false,
      false,
      false,
    ),
  }

  action doReplaceArmorWithEldritchMindOnWarlockLevelGain = all {
    qState.outcome == CharacterCreationWarlockEldritchInvocationsSelectedIdentityInit,
    recordProjection(
      CharacterCreationWarlockEldritchInvocationsSelectedIdentityNonRepeatableReplaced,
      "warlock_eldritch_invocations",
      3,
      0,
      true,
      false,
      true,
      true,
      true,
      false,
      false,
      false,
      false,
      2,
      4,
      2,
      2,
      3,
      false,
      false,
      false,
    ),
  }

  action doReplaceRepeatableInvocationByChoice = all {
    qState.outcome == CharacterCreationWarlockEldritchInvocationsSelectedIdentityInit,
    recordProjection(
      CharacterCreationWarlockEldritchInvocationsSelectedIdentityRepeatableReplaced,
      "warlock_eldritch_invocations",
      3,
      0,
      true,
      true,
      false,
      true,
      false,
      false,
      false,
      true,
      false,
      2,
      4,
      2,
      2,
      3,
      false,
      false,
      false,
    ),
  }

  action doRejectPrerequisiteRetainedInvocationReplacement = all {
    qState.outcome == CharacterCreationWarlockEldritchInvocationsSelectedIdentityInit,
    recordProjection(
      CharacterCreationWarlockEldritchInvocationsSelectedIdentityLockedReplacementRejected,
      "warlock_eldritch_invocations",
      5,
      0,
      true,
      true,
      true,
      true,
      true,
      true,
      false,
      false,
      false,
      3,
      6,
      2,
      3,
      5,
      true,
      false,
      false,
    ),
  }

  action doRejectDuplicateInvocationSelections = all {
    qState.outcome == CharacterCreationWarlockEldritchInvocationsSelectedIdentityInit,
    recordProjection(
      CharacterCreationWarlockEldritchInvocationsSelectedIdentityDuplicateSelectionRejected,
      "warlock_eldritch_invocations",
      1,
      0,
      true,
      true,
      false,
      false,
      false,
      false,
      false,
      false,
      false,
      2,
      2,
      1,
      1,
      1,
      false,
      true,
      true,
    ),
  }

  action step = any {
    doSelectLevelOneArmorOfShadows,
    doGainLevelTwoInvocations,
    doReplaceArmorWithEldritchMindOnWarlockLevelGain,
    doReplaceRepeatableInvocationByChoice,
    doRejectPrerequisiteRetainedInvocationReplacement,
    doRejectDuplicateInvocationSelections,
  }
}
